# Copy to .env and fill values locally. Never commit .env.

# LLM (OpenRouter)
OPENAI_API_KEY=

# Long-term memory (Zep Cloud)
ZEP_API=

# PostgreSQL (Streamlit user profiles)
POSTGRESQL_USER=
POSTGRESQL_PASSWORD=
POSTGRESQL_HOST=
POSTGRESQL_PORT=
POSTGRESQL_DBNAME=

# Qdrant (loaded in config; optional)
QDRANT_URL=
QDRANT_API_KEY=

# HuggingFace
HUGGINGFACEHUB_API_TOKEN=

# Langfuse observability (optional — Phase 7)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Stream API authentication (SEC-04)
STREAM_API_KEY=
